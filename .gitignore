# ─── Dependencies ───────────────────────────────────────────────────────────
node_modules/

# ─── Expo / Metro ───────────────────────────────────────────────────────────
.expo/
expo-env.d.ts
dist/
web-build/
.metro-health-check*

# ─── Native build output (regenerated by prebuild / run:android) ─────────────
android/
ios/

# ─── EAS Build ──────────────────────────────────────────────────────────────
.eas/
eas-build-post-install.js

# ─── Signing / certificates (never commit these) ────────────────────────────
*.jks
*.p8
*.p12
*.key
*.keystore
*.mobileprovision
*.cer
*.certSigningRequest

# ─── Vosk model — large binary, distribute separately ───────────────────────
assets/model-en-in/
!assets/model-en-in/.gitkeep

# ─── CSV exports & user data ────────────────────────────────────────────────
exports/
*.csv
*.sqlite
*.db

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS / editor artifacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.orig.*
.idea/
.vscode/
*.swp
*.swo

# ─── TypeScript build cache ──────────────────────────────────────────────────
*.tsbuildinfo

# ─── Test / coverage ────────────────────────────────────────────────────────
coverage/
.jest-cache/

# ─── Env files (keep .env.example if present) ───────────────────────────────
.env
.env.local
.env.*.local