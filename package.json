{
  "name": "voicekhata",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "prebuild": "expo prebuild --platform android",
    "build:android": "cd android && ./gradlew assembleDebug",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "expo": "~56.0.12",
    "expo-file-system": "~56.0.8",
    "expo-router": "~56.2.11",
    "expo-sharing": "~56.0.18",
    "expo-speech": "~56.0.3",
    "expo-sqlite": "~56.0.5",
    "expo-status-bar": "~56.0.4",
    "fuse.js": "^7.1.0",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-vosk": "^2.1.7",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@react-native/jest-preset": "^0.86.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "@types/react-test-renderer": "^18.3.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "typescript": "~6.0.3"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.tsx?$": [
        "babel-jest",
        {
          "configFile": "./babel.config.js"
        }
      ]
    },
    "testMatch": [
      "**/src/parser/**/*.test.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ]
  },
  "private": true
}
